{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"extends": "//",
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/.github",
			"!**/playwright-report",
			"!**/test-results",
			"!**/coverage",
			"!**/.next",
			"!**/node_modules"
		]
	},
	"css": {
		"parser": {
			"cssModules": true,
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["**/components/ui/role-badge.test.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"useValidAriaRole": "off"
					}
				}
			}
		}
	]
}
