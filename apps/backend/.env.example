NODE_ENV=production
PORT=3333
HOST='0.0.0.0'
PASSWORD_SALT=12
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRIVATE_KEY='REPLACE_WITH_YOUR_OWN_SECURELY_GENERATED_KEY_MIN_32_CHARS'
CHECK_IN_EXPIRATION_TIME=20
JWT_EXPIRES_IN="10m"
JWT_REFRESH_EXPIRES_IN="7d"
REFRESH_TOKEN_NAME="refreshToken"
ITEMS_PER_PAGE=20
AMQP_URL='amqp://localhost'
# Database
DATABASE_PROVIDER='prisma'
# Subscription gateway: 'stripe' for real Stripe API, 'testing' for demo/test mode (no real charges)
SUBSCRIPTION_GATEWAY='testing'
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=apisolid
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://docker:docker@localhost:5432/apisolid?schema=public"
sslmode=require
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
TTL=60
GOOGLE_CLIENT_ID=REDACTED_GOOGLE_CLIENT_ID
CORS_ORIGINS=https://app.seudominio.com,https://admin.seudominio.com
# Supabase
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?schema=public&sslmode=require&pgbouncer=true
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require
# Email (SMTP)
# Deixe vazio para usar conta Ethereal de teste (desenvolvimento)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="No Reply <noreply@seudominio.com>"
