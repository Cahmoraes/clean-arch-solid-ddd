NODE_ENV=production
PORT=3333
HOST='0.0.0.0'
PASSWORD_SALT=2
PRIVATE_KEY='private-key-example'
CHECK_IN_EXPIRATION_TIME=20
JWT_EXPIRES_IN="10m"
JWT_REFRESH_EXPIRES_IN="7d"
REFRESH_TOKEN_NAME="refreshToken"
ITEMS_PER_PAGE=20
AMQP_URL='amqp://localhost'
# Database
DATABASE_PROVIDER='sqlite'
# Subscription gateway: 'stripe' for real Stripe API, 'testing' for demo/test mode (no real charges)
SUBSCRIPTION_GATEWAY='testing'
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=apisolid
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://docker:docker@localhost:5432/apisolid?schema=public"
sslmode=require
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
TTL=60
GOOGLE_CLIENT_ID=REDACTED_GOOGLE_CLIENT_ID
# Supabase
# DATABASE_URL=postgresql://postgres.REDACTED_PROJECT_ID:REDACTED_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?schema=public&sslmode=require&pgbouncer=true
# DIRECT_URL=postgresql://postgres.REDACTED_PROJECT_ID:REDACTED_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?schema=public&sslmode=require&pgbouncer=true