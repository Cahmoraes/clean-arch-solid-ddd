{
	"name": "03-api-solid",
	"version": "1.0.0",
	"main": "./build/main.js",
	"types": "build/main.d.ts",
	"type": "module",
	"scripts": {
		"start": "node ./build/main.js",
		"dev": "npm run docker:up && npm run wait:rabbit && npm run wait:db && npx tsx --watch src/main.ts",
		"wait:db": "npx tsx src/shared/infra/database/connection/waiting-for-postgres.ts",
		"wait:rabbit": "npx tsx src/shared/infra/queue/waiting-for-rabbitmq.ts",
		"setup-queue": "npx tsx src/shared/infra/queue/queue-setup.ts",
		"test": "npx vitest --config ./test/vite.config.app-domain.ts",
		"test:run": "npx vitest run --config ./test/vite.config.app-domain.ts",
		"test-create-users": "concurrently \"npx tsx ./test/test.post.ts\" \"npx tsx ./test/test.post.ts\" \"npx tsx ./test/test.post.ts\" \"npx tsx ./test/test.post.ts\"",
		"test:cov": "npx vitest --coverage --config ./test/vite.config.app-domain.ts",
		"test:business-flow": "npx vitest run --config ./test/vite.config.business-flow.ts",
		"test:e2e:prisma": "vitest --config ./test/vite.config.integration.ts",
		"test:fitness": "vitest --config ./test/vite.config.fitness.ts",
		"build": "pnpm tsup",
		"prisma:studio": "npx prisma studio --url postgresql://docker:docker@localhost:5432/apisolid --browser none",
		"prisma:generate": "npx prisma generate",
		"prisma:migrate:dev": "npx prisma migrate dev",
		"prisma:schema": "npx prisma migrate diff --from-empty --to-schema-datamodel ./prisma/schema.prisma --script >supabase-schema.sql",
		"prisma:reset": "npx prisma migrate reset --force",
		"prisma:deploy": "npx prisma migrate deploy",
		"prisma:db:pull": "npx prisma db pull",
		"tsc:check": "npx tsc --noEmit",
		"biome:fix": "biome check --write .",
		"promise-like": "npx tsx --watch ./test/proxy-like/index-2.ts",
		"commit": "cz",
		"fit:validate-dependencies": "npx depcruise --validate .dependency-cruiser.js src",
		"dependency:metrics": "npx depcruise .dependency-cruiser.js src --include-only \"^src\" --output-type dot | dot -T svg > dependency-graph.svg",
		"check:last-dependencies": "npx npm-check-updates -i",
		"stripe webhook": "stripe listen --forward-to localhost:3333/webhook/stripe",
		"worker": "npx tsx --watch src/shared/infra/worker/worker.ts",
		"docker:up": "docker compose -f compose.yaml up -d",
		"docker:down": "docker compose -f compose.yaml down",
		"docker:build": "docker build --pull --tag clean-arch-solid-ddd:latest --tag clean-arch-solid-ddd:$npm_package_version .",
		"docker:build:nocache": "docker build --pull --no-cache --tag clean-arch-solid-ddd:latest --tag clean-arch-solid-ddd:$npm_package_version .",
		"docker:run": "docker run --rm -p 3333:3333 --env-file .env --name clean-arch-solid-ddd clean-arch-solid-ddd:latest"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/amqplib": "0.10.8",
		"@types/better-sqlite3": "7.6.13",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "25.6.0",
		"@types/nodemailer": "8.0.0",
		"@types/pg": "8.20.0",
		"@types/set-cookie-parser": "2.4.10",
		"@types/supertest": "7.2.0",
		"@vitest/coverage-v8": "4.1.5",
		"archunit": "2.1.69",
		"concurrently": "9.2.1",
		"cz-conventional-changelog": "3.3.0",
		"dependency-cruiser": "17.3.10",
		"prisma": "7.8.0",
		"supertest": "7.2.2",
		"tsx": "4.21.0",
		"vite": "8.0.10",
		"vitest": "4.1.5"
	},
	"dependencies": {
		"@cahmoraes93/extended-set": "1.2.1",
		"@faker-js/faker": "10.4.0",
		"@fastify/cors": "11.2.0",
		"@fastify/swagger": "9.7.0",
		"@fastify/swagger-ui": "5.2.6",
		"@prisma/adapter-pg": "7.8.0",
		"@prisma/client": "7.8.0",
		"amqplib": "1.0.3",
		"bcryptjs": "3.0.3",
		"better-sqlite3": "12.9.0",
		"bullmq": "5.76.2",
		"commitizen": "4.3.1",
		"cookie": "1.1.1",
		"dotenv": "17.4.2",
		"fastify": "5.8.5",
		"inversify": "8.1.0",
		"ioredis": "5.10.1",
		"jsonwebtoken": "9.0.3",
		"lru-cache": "11.3.5",
		"node-cache": "5.1.2",
		"node-cron": "4.2.1",
		"nodemailer": "8.0.6",
		"pg": "8.20.0",
		"reflect-metadata": "0.2.2",
		"set-cookie-parser": "3.1.0",
		"stripe": "22.1.0",
		"tsup": "8.5.1",
		"typescript": "6.0.3",
		"winston": "3.19.0",
		"zod": "4.3.6",
		"zod-validation-error": "5.0.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
